# Copy to .env and adjust. DB + Redis are your existing Docker containers.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/parse_companies?sslmode=disable
REDIS_URL=redis://localhost:6379/0
OVERPASS_URL=https://overpass-api.de/api/interpreter
NOMINATIM_URL=https://nominatim.openstreetmap.org
WIKIDATA_URL=https://query.wikidata.org/sparql
HTTP_ADDR=:8080

# Email campaigns (optional). Leave SMTP_HOST empty to disable the feature.
# Use YOUR OWN SMTP account — you are the accountable sender. Only email
# recipients who have consented; unsolicited bulk email is regulated.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=Your Name <you@example.com>
CAMPAIGN_DELAY_MS=1000
CAMPAIGN_MAX=500

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8080
