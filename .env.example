# Copy to .env and adjust. DB + Redis are your existing Docker containers.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/parse_companies?sslmode=disable
REDIS_URL=redis://localhost:6379/0
OVERPASS_URL=https://overpass-api.de/api/interpreter
NOMINATIM_URL=https://nominatim.openstreetmap.org
WIKIDATA_URL=https://query.wikidata.org/sparql
HTTP_ADDR=:8080

# Email campaigns (optional). Disabled until a provider is configured.
# Use YOUR OWN account — you are the accountable sender. Only email recipients
# who have consented; unsolicited bulk email is regulated.
#
# MAIL_PROVIDER: "smtp" (default) | "resend" | "brevo".
# HTTP providers (resend/brevo) send over HTTPS and work where SMTP ports are
# blocked. They need only MAIL_API_KEY (free tiers available).
MAIL_PROVIDER=smtp
MAIL_API_KEY=

# From address (all providers). For resend/brevo it must be a verified sender.
SMTP_FROM=Your Name <you@example.com>

# SMTP settings (only when MAIL_PROVIDER=smtp)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=

CAMPAIGN_DELAY_MS=1000
CAMPAIGN_MAX=500

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8080
